<Project Sdk="Microsoft.NET.Sdk">

	<!--
	The whole test suite spawns the real net481 ExternalUpdater.exe and uses Windows-only
	helpers (ping.exe, cmd .bat stubs). On Linux:
	  * The project targets net10.0 instead of net481 so `dotnet test` runs it under .NET 10
	    (no mono needed).
	  * All source files are excluded — the test scenarios reference net481-only types
	    (ExternalUpdater.App is net481-only) and use Windows APIs.
	  * The reference to ExternalUpdater.App is dropped (net10.0 → net481 reference would fail).
	The result on Linux is an empty test exe that `dotnet test` invokes successfully and finds
	no tests in.
	-->
	<PropertyGroup>
		<TargetFrameworks Condition="!$([MSBuild]::IsOsUnixLike())">net481</TargetFrameworks>
		<TargetFrameworks Condition="$([MSBuild]::IsOsUnixLike())">net10.0</TargetFrameworks>
		<RootNamespace>AnakinRaW.ExternalUpdater.Test</RootNamespace>
		<LangVersion>preview</LangVersion>
	</PropertyGroup>

	<PropertyGroup>
		<IsPackable>false</IsPackable>
		<IsTestable>true</IsTestable>
		<OutputType>Exe</OutputType>
	</PropertyGroup>

	<ItemGroup Condition="$([MSBuild]::IsOsUnixLike())">
		<Compile Remove="@(Compile)" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="AnakinRaW.CommonUtilities" Version="13.0.18" />
		<PackageReference Include="AnakinRaW.CommonUtilities.Testing" Version="13.0.18" />
		<PackageReference Include="GitHubActionsTestLogger" Version="3.0.4" />
		<PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.7" />
		<PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.5.1" />
		<PackageReference Include="Testably.Abstractions" Version="10.2.0" />
		<PackageReference Include="xunit.v3.mtp-v2" Version="3.2.2" />
		<PackageReference Include="Microsoft.Testing.Platform" Version="2.2.2" />
		<PackageReference Include="xunit.runner.visualstudio" Version="3.1.5">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="coverlet.collector" Version="10.0.0">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
	</ItemGroup>

	<ItemGroup>
		<!-- ExternalUpdater.App is net481-only; can only be referenced from a net481 consumer. -->
		<ProjectReference Include="..\..\..\src\Updater\ExternalUpdater.App\ExternalUpdater.App.csproj"
		                  Condition="!$([MSBuild]::IsOsUnixLike())" />
		<ProjectReference Include="..\..\..\src\Updater\ExternalUpdater.Core\ExternalUpdater.Core.csproj" />
	</ItemGroup>

</Project>
